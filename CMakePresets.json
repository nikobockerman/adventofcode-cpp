{
  "version": 8,
  "include": [
    "./ConanPresets.json"
  ],
  "configurePresets": [
    {
      "name": "MSVC",
      "displayName": "MS Visual Studio Compiler",
      "description": "Main - Visual Studio Compiler preset with Conan generated toolchain",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "inherits": [
        "conan-msvc"
      ],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_INIT": "/W4 /WX /EHsc"
      }
    },
    {
      "hidden": true,
      "name": "ClangGccFlags",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS_INIT": "-Wall -Wextra -Werror"
      }
    },
    {
      "name": "Clang",
      "displayName": "Clang Windows",
      "description": "Main - Clang Windows preset with Conan generated toolchain and Multi-Config generator",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "inherits": [
        "conan-clang",
        "ClangGccFlags"
      ]
    },
    {
      "name": "GccDebug",
      "displayName": "Gcc Debug",
      "description": "Main - Gcc Debug preset with Conan generated toolchain",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "inherits": [
        "conan-gcc-debug",
        "ClangGccFlags"
      ]
    },
    {
      "name": "GccRelease",
      "displayName": "Gcc Release",
      "description": "Main - Gcc Release preset with Conan generated toolchain",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "inherits": [
        "conan-gcc-release",
        "ClangGccFlags"
      ]
    },
    {
      "name": "ClangDebug",
      "displayName": "Clang Debug",
      "description": "Main - Clang Debug preset with Conan generated toolchain",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "inherits": [
        "conan-clang-debug",
        "ClangGccFlags"
      ]
    },
    {
      "name": "ClangRelease",
      "displayName": "Clang Release",
      "description": "Main - Clang Release preset with Conan generated toolchain",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "inherits": [
        "conan-clang-release",
        "ClangGccFlags"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "MSVC Debug",
      "configurePreset": "MSVC",
      "configuration": "Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "MSVC Release",
      "configurePreset": "MSVC",
      "configuration": "Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Clang Debug",
      "configurePreset": "Clang",
      "configuration": "Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "Clang Release",
      "configurePreset": "Clang",
      "configuration": "Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "GccRelease",
      "displayName": "Gcc Release",
      "configurePreset": "GccRelease",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "GccDebug",
      "displayName": "Gcc Debug",
      "configurePreset": "GccDebug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ClangDebug",
      "displayName": "Clang Debug",
      "configurePreset": "ClangDebug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ClangRelease",
      "displayName": "Clang Release",
      "configurePreset": "ClangRelease",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "MSVC",
      "steps": [
        {
          "type": "configure",
          "name": "MSVC"
        }
      ]
    }
  ]
}
